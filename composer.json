{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-fileinfo": "*",
        "ext-iconv": "*",
        "api-platform/doctrine-orm": "^4.1.9",
        "api-platform/graphql": "^4.1.9",
        "api-platform/symfony": "^4.1.9",
        "cweagans/composer-patches": "^1.7",
        "doctrine/dbal": "^3.9.4",
        "doctrine/doctrine-bundle": "^2.14",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.3.3",
        "gesdinet/jwt-refresh-token-bundle": "^1.5",
        "nelmio/cors-bundle": "^2.5",
        "nikic/php-parser": "^5.6",
        "paragonie/sodium_compat": "^2.1",
        "phpdocumentor/reflection-docblock": "^5.6.2",
        "phpstan/phpdoc-parser": "^2.1",
        "phpunit/phpunit": "^12.1.5",
        "sentry/sentry-symfony": "^5.2",
        "symfony/asset": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/expression-language": "7.2.*",
        "symfony/flex": "^2.5.1",
        "symfony/framework-bundle": "7.2.*",
        "symfony/http-client": "7.2.*",
        "symfony/mailer": "7.2.*",
        "symfony/property-access": "7.2.*",
        "symfony/property-info": "7.2.*",
        "symfony/runtime": "7.2.*",
        "symfony/security-bundle": "7.2.*",
        "symfony/serializer": "7.2.*",
        "symfony/translation": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/validator": "7.2.*",
        "symfony/yaml": "7.2.*",
        "symfonycasts/reset-password-bundle": "^1.23.1",
        "symfonycasts/verify-email-bundle": "^1.17.3",
        "twig/extra-bundle": "^2.12|^3.21",
        "twig/twig": "^2.12|^3.21.1"
    },
    "config": {
        "allow-plugins": {
            "brainmaestro/composer-git-hooks": true,
            "cweagans/composer-patches": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts",
            "cghooks add --ignore-lock"
        ],
        "post-update-cmd": [
            "@auto-scripts",
            "cghooks update"
        ],
        "start": [
            "symfony serve:start"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        },
        "patches": {
            "symfony/translation": {
                "Preserve spaces in nested translation keys instead of using dots": "patches/space-key-separator-arrayloader.patch",
                "make trans() resolve space-separated translation keys": "patches/translation-arrayconverter-separator.patch"
            }
        },
        "hooks": {
            "post-checkout": [
                "git submodule update --init --recursive",
                "git status"
                ],
            "post-merge": [
                "git submodule update --init --recursive",
                "git status"
            ]
        }
    },
    "require-dev": {
        "brainmaestro/composer-git-hooks": "^3.0",
        "symfony/browser-kit": "7.2.*",
        "symfony/maker-bundle": "^1.63.0",
        "symfony/stopwatch": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*"
    }
}
